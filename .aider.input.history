+
+def mouseReleaseEvent(self, event):
+    # Вызываем базовый метод, чтобы Qt штатно завершил RubberBand и сам выделил элементы на сцене
+    super().mouseReleaseEvent(event)
+    
+    # Теперь просто берем элементы, которые Qt УЖЕ успешно добавил в свой стандартный список выделения
+    for item in self.selectedItems():
