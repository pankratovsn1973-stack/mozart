# 2026-06-04 22:44:04.073062
+В файле widgets/form_designer_old/form_scene.py перепиши метод mouseReleaseEvent. Вьювер сбрасывает групповой выбор. 
+Нам нужно принудительно перебрать все элементы, которые попали в область выделения в момент отпускания мыши:
+
+def mouseReleaseEvent(self, event):
+    # Вызываем базовый метод, чтобы Qt завершил RubberBand
+    super().mouseReleaseEvent(event)
+    
+    # Собираем ВСЕ элементы, которые сейчас оказались выделены встроенной рамкой Qt
+    selected_items = self.selectedItems()
+    
+    # Если мы выделили группу, принудительно зажигаем маркеры для каждого ControlItem
+    for item in selected_items:
+        if hasattr(item, 'set_selected'):
+            item.set_selected(True)
+            
+    # Дополнительно вызываем обновление маркеров ресайза на сцене, если такой метод есть
+    if hasattr(self, 'update_resize_handles_position'):
+        self.update_resize_handles_position()
+

# 2026-06-04 22:51:04.281281
+Встроенная логика Qt Graphics View после RubberBand принудительно сбрасывает множественный выбор до одного элемента в самом конце события. Давай заблокируем этот сброс и принудительно зафиксируем выделение пачки элементов в файле widgets/form_designer_old/form_scene.py.
+
+Перепиши метод mouseReleaseEvent следующим образом:
+
+def mouseReleaseEvent(self, event):
+    # 1. ЗАПОМИНАЕМ область выделения RubberBand ДО того, как базовый класс всё сбросит
+    # Считываем прямоугольник, который очертил пользователь на экране
+    rubber_band_rect = self.views()[0].rubberBandRect()
+    
+    if not rubber_band_rect.isEmpty():
+        # Переводим экранные координаты в координаты нашей 2D-сцены
+        scene_rect = self.views()[0].mapToScene(rubber_band_rect).boundingRect()
+        
+        # Находим ВТИХУЮ абсолютно все ControlItem, которые попали внутрь этой рамки
+        items_in_band = [item for item in self.items(scene_rect) if hasattr(item, 'set_selected')]
+        
+        # 2. Вызываем базовый метод, пускай Qt завершает свои внутренние процессы
+        super().mouseReleaseEvent(event)
+        
+        # 3. ЖЕСТКО восстанавливаем групповое выделение поверх базового сброса Qt
+        self.clearSelection() # Сначала чистим мусор
+        for item in items_in_band:
+            item.setSelected(True)      # Включаем стандартный флаг Qt
+            if hasattr(item, 'set_selected'):
+                item.set_selected(True) # Включаем синие маркеры ресайза
+                
+        # Обновляем маркеры ресайза на сцене
+        if hasattr(self, 'update_resize_handles_position'):
+            self.update_resize_handles_position()
+    else:
+        # Если это был обычный одиночный клик, а не рамка — пускай Qt работает штатно
+        super().mouseReleaseEvent(event)
+

