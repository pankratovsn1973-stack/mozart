# 2026-06-04 23:05:22.474076
+Мы полностью сломали логику кликов: левая кнопка не выделяет, правая кнопка выделяет и сбрасывает Ctrl. Давай полностью перепишем обработку мыши в control_item.py и form_scene.py на чистый, эталонный стандарт Qt, чтобы вернуть базовое выделение (включая Ctrl) в рабочее состояние.
+
+1. В файле widgets/form_designer_old/control_item.py полностью перепиши методы мыши:
+
+def mousePressEvent(self, event):
+    # Если нажата левая кнопка — отдаем управление базовому классу Qt для стандартного выделения/перемещения
+    if event.button() == Qt.LeftButton:
+        super().mousePressEvent(event)
+    # Если нажата правая кнопка — выделяем этот элемент и НЕ сбрасываем сцену
+    elif event.button() == Qt.RightButton:
+        self.setSelected(True)
+        self.set_selected(True)
+        super().mousePressEvent(event)
+
+def mouseMoveEvent(self, event):
+    super().mouseMoveEvent(event)
+
+def mouseReleaseEvent(self, event):
+    super().mouseReleaseEvent(event)
+    # Синхронизируем синие маркеры ресайза по флагу выделения Qt
+    self.set_selected(self.isSelected())
+
+2. В файле widgets/form_designer_old/form_scene.py полностью очисти методы мыши от кастомных условий, вернув чистый проброс событий:
+
+def mousePressEvent(self, event):
+    super().mousePressEvent(event)
+
+def mouseMoveEvent(self, event):
+    super().mouseMoveEvent(event)
+
+def mouseReleaseEvent(self, event):
+    super().mouseReleaseEvent(event)
+    # После отпускания мыши (клик или RubberBand) просто обновляем маркеры для всех ControlItem на сцене
+    for item in self.items():
+        if hasattr(item, 'set_selected'):
+            item.set_selected(item.isSelected())
+            
+    if hasattr(self, 'update_resize_handles_position'):
+        self.update_resize_handles_position()
+

# 2026-06-04 23:10:17.152415
+Внедренные изменения полностью сломали режим дизайна формы: виджеты стали активными (в них можно вводить текст), а сами графические контейнеры ControlItem перестали выделяться и двигаться по сцене. Давай жестко заблокируем фокус виджетов и вернем управление контейнеру.
+
+Исправь файл widgets/form_designer_old/control_item.py:
+
+1. В конструкторе __init__ после добавления виджета принудительно отключи для него фокус клавиатуры и мыши в режиме дизайна:
+   if self.widget():
+       self.widget().setFocusPolicy(Qt.NoFocus)
+       self.widget().setAttribute(Qt.WA_TransparentForMouseEvents, True)
+
+2. Перепиши метод mousePressEvent так, чтобы он ЖЕСТКО перехватывал управление и не пускал клики мыши внутрь кнопок и текстбоксов:
+def mousePressEvent(self, event):
+    # Принудительно принимаем событие на уровне графического контейнера
+    event.accept()
+    
+    if event.button() == Qt.LeftButton:
+        # Включаем стандартный флаг выделения Qt Graphics Item
+        self.setSelected(True)
+        self.set_selected(True)
+        # Передаем управление базовому классу графического элемента, чтобы работал сдвиг мышью
+        super().mousePressEvent(event)
+    elif event.button() == Qt.RightButton:
+        self.setSelected(True)
+        self.set_selected(True)
+        # Вызываем контекстное меню, если метод определен
+        if hasattr(self, 'show_context_menu'):
+            self.show_context_menu(event.screenPos())
+
+3. Убедись, что метод mouseMoveEvent также передает управление базовому классу для плавной буксировки элемента:
+def mouseMoveEvent(self, event):
+    super().mouseMoveEvent(event)
+

# 2026-06-04 23:12:11.242773
+Внедренные изменения полностью отключили режим дизайна: ВСЕ контролы (кнопки, чекбоксы, текстбоксы) ведут себя как на работающей форме, кликаются и перехватывают фокус. Нам нужно полностью изолировать внутренние виджеты от мыши и вернуть управление графическому контейнеру.
+
+Перепиши файл widgets/form_designer_old/control_item.py, вернув жесткий перехват событий графического элемента:
+
+1. В методе mousePressEvent:
+def mousePressEvent(self, event):
+    # Жестко говорим Qt: клик обработан на уровне контейнера, внутрь кнопок и чекбоксов его не пускать!
+    event.accept()
+    
+    # Стандартная обработка выделения
+    self.setSelected(True)
+    self.set_selected(True)
+    
+    if event.button() == Qt.LeftButton:
+        # Пробрасываем в базовый класс графического элемента, чтобы работало перемещение (drag)
+        super().mousePressEvent(event)
+    elif event.button() == Qt.RightButton:
+        # Вызываем контекстное меню удаления/свойств
+        if hasattr(self, 'show_context_menu'):
+            self.show_context_menu(event.screenPos())
+
+2. Убедись, что метод mouseMoveEvent и mouseReleaseEvent также вызывают базовые методы GraphicsItem:
+def mouseMoveEvent(self, event):
+    super().mouseMoveEvent(event)
+
+def mouseReleaseEvent(self, event):
+    super().mouseReleaseEvent(event)
+

# 2026-06-04 23:29:39.086752
+Запомни архитектурное правило для проекта Mozart:
+1. Контролы на сцене упакованы в QGraphicsProxyWidget (класс ControlItem). Чтобы они не оживали в режиме дизайна (чекбоксы не кликались, текстбоксы не принимали текст), стандартные методы QtWA_TransparentForMouseEvents не работают из-за множественного наследования от BaseControl.
+2. Единственный рабочий способ изолировать виджеты — использовать QObject.installEventFilter() (класс DesignEventFilter), который перехватывает MouseButtonPress, KeyPress и блокирует их прохождение внутрь виджета.
+3. Для группового перемещения нельзя использовать super().mouseMoveEvent(). Нужно вручную фиксировать словарь стартовых позиций выделенных элементов self._group_start_positions при mousePressEvent и синхронно двигать их по дельте смещения мыши в mouseMoveEvent.
+Никогда больше не заменяй эти методы на стандартные вызовы super() в Graphics View!
+

