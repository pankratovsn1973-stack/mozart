\par \pard\plain \s0\rtlch\af13\afs24\alang1081 \ltrch\lang1049\langfe2052\hich\af3\loch\ql\widctlpar\hyphpar0\ltrpar\cf0\f3\fs24\lang1049\kerning1\dbch\af9\langfe2052{\loch
\u1052\'3f\u1099\'3f \u1086\'3f\u1073\'3f\u1089\'3f\u1091\'3f\u1076\'3f\u1080\'3f\u1083\'3f\u1080\'3f, \u1095\'3f\u1090\'3f\u1086\'3f \u1073\'3f\u1072\'3f\u1083\'3f\u1072\'3f\u1085\'3f\u1089\'3f\u1086\'3f\u1074\'3f\u1099\'3f\u1077\'3f \u1077\'3f\u1076\'3f\u1080\'3f\u1085\'3f\u1080\'3f\u1094\'3f\u1099\'3f \u8211\'96 \u1080\'3f\u1077\'3f\u1088\'3f\u1072\'3f\u1088\'3f\u1093\'3f\u1080\'3f\u1095\'3f\u1077\'3f\u1089\'3f\u1082\'3f\u1080\'3f\u1081\'3f \u1089\'3f\u1087\'3f\u1088\'3f\u1072\'3f\u1074\'3f\u1086\'3f\u1095\'3f\u1085\'3f\u1080\'3f\u1082\'3f. \u1047\'3f\u1085\'3f\u1072\'3f\u1095\'3f\u1080\'3f\u1090\'3f, \u1085\'3f\u1091\'3f\u1078\'3f\u1077\'3f\u1085\'3f QTreeView (\u1080\'3f\u1083\'3f\u1080\'3f QTreeWidget) \u1076\'3f\u1083\'3f\u1103\'3f \u1086\'3f\u1090\'3f\u1086\'3f\u1073\'3f\u1088\'3f\u1072\'3f\u1078\'3f\u1077\'3f\u1085\'3f\u1080\'3f\u1103\'3f \u1080\'3f\u1077\'3f\u1088\'3f\u1072\'3f\u1088\'3f\u1093\'3f\u1080\'3f\u1080\'3f. \u1042\'3f \u1090\'3f\u1072\'3f\u1073\'3f\u1083\'3f\u1080\'3f\u1094\'3f\u1077\'3f balanceunits \u1077\'3f\u1089\'3f\u1090\'3f\u1100\'3f \u1087\'3f\u1086\'3f\u1083\'3f\u1077\'3f parentid, \u1095\'3f\u1090\'3f\u1086\'3f \u1087\'3f\u1086\'3f\u1079\'3f\u1074\'3f\u1086\'3f\u1083\'3f\u1103\'3f\u1077\'3f\u1090\'3f \u1089\'3f\u1090\'3f\u1088\'3f\u1086\'3f\u1080\'3f\u1090\'3f\u1100\'3f \u1076\'3f\u1077\'3f\u1088\'3f\u1077\'3f\u1074\'3f\u1086\'3f. \u1058\'3f\u1072\'3f\u1082\'3f\u1078\'3f\u1077\'3f \u1074\'3f \u1079\'3f\u1072\'3f\u1082\'3f\u1083\'3f\u1072\'3f\u1076\'3f\u1082\'3f\u1072\'3f\u1093\'3f \u1076\'3f\u1086\'3f\u1083\'3f\u1078\'3f\u1077\'3f\u1085\'3f \u1073\'3f\u1099\'3f\u1090\'3f\u1100\'3f \u1084\'3f\u1080\'3f\u1085\'3f\u1080\'3f\u1084\'3f\u1072\'3f\u1083\'3f\u1100\'3f\u1085\'3f\u1099\'3f\u1081\'3f \u1085\'3f\u1072\'3f\u1073\'3f\u1086\'3f\u1088\'3f: "\u1041\'3f\u1072\'3f\u1083\'3f\u1072\'3f\u1085\'3f\u1089\'3f\u1086\'3f\u1074\'3f\u1099\'3f\u1077\'3f \u1077\'3f\u1076\'3f\u1080\'3f\u1085\'3f\u1080\'3f\u1094\'3f\u1099\'3f", "\u1055\'3f\u1086\'3f\u1083\'3f\u1100\'3f\u1079\'3f\u1086\'3f\u1074\'3f\u1072\'3f\u1090\'3f\u1077\'3f\u1083\'3f\u1080\'3f \u1080\'3f \u1088\'3f\u1086\'3f\u1083\'3f\u1080\'3f", "\u1056\'3f\u1072\'3f\u1073\'3f\u1086\'3f\u1090\'3f\u1072\'3f \u1089\'3f \u1089\'3f\u1091\'3f\u1097\'3f\u1085\'3f\u1086\'3f\u1089\'3f\u1090\'3f\u1103\'3f\u1084\'3f\u1080\'3f", "\u1044\'3f\u1086\'3f\u1082\'3f\u1091\'3f\u1084\'3f\u1077\'3f\u1085\'3f\u1090\'3f\u1099\'3f \u1080\'3f \u1084\'3f\u1072\'3f\u1088\'3f\u1096\'3f\u1088\'3f\u1091\'3f\u1090\'3f\u1099\'3f", "\u1054\'3f\u1087\'3f\u1077\'3f\u1088\'3f\u1072\'3f\u1090\'3f\u1080\'3f\u1074\'3f\u1085\'3f\u1099\'3f\u1081\'3f \u1087\'3f\u1088\'3f\u1086\'3f\u1089\'3f\u1084\'3f\u1086\'3f\u1090\'3f\u1088\'3f \u1089\'3f\u1087\'3f\u1088\'3f\u1072\'3f\u1074\'3f\u1086\'3f\u1095\'3f\u1085\'3f\u1080\'3f\u1082\'3f\u1086\'3f\u1074\'3f", "\u1057\'3f\u1074\'3f\u1103\'3f\u1079\'3f\u1080\'3f \u1089\'3f\u1091\'3f\u1097\'3f\u1085\'3f\u1086\'3f\u1089\'3f\u1090\'3f\u1077\'3f\u1081\'3f". \u1059\'3f \u1085\'3f\u1072\'3f\u1089\'3f \u1089\'3f\u1077\'3f\u1081\'3f\u1095\'3f\u1072\'3f\u1089\'3f \u1090\'3f\u1086\'3f\u1083\'3f\u1100\'3f\u1082\'3f\u1086\'3f \u1076\'3f\u1074\'3f\u1077\'3f \u1074\'3f\u1082\'3f\u1083\'3f\u1072\'3f\u1076\'3f\u1082\'3f\u1080\'3f (BU \u1080\'3f Entities), \u1085\'3f\u1086\'3f \u1084\'3f\u1099\'3f \u1076\'3f\u1086\'3f\u1083\'3f\u1078\'3f\u1085\'3f\u1099\'3f \u1076\'3f\u1086\'3f\u1073\'3f\u1072\'3f\u1074\'3f\u1080\'3f\u1090\'3f\u1100\'3f \u1086\'3f\u1089\'3f\u1090\'3f\u1072\'3f\u1083\'3f\u1100\'3f\u1085\'3f\u1099\'3f\u1077\'3f.}
